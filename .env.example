# Copy to ".env" and fill in real values. NEVER commit the real .env file.
# Used by docker-compose.prod.yml.

# --- Domain / TLS (Caddy edge) ---
# Public hostname; Caddy provisions Let's Encrypt TLS for it automatically.
# For local HTTP-only testing use ":80".
SITE_ADDRESS=sailboats.com.pl
# Contact email for Let's Encrypt (renewal/expiry notices).
ACME_EMAIL=admin@sailboats.com.pl

# --- Allowed browser origins for the simulation WebSocket (backend CORS) ---
APP_CORS_ALLOWED_ORIGINS=https://sailboats.com.pl

# --- PostgreSQL (fleet + simulation) ---
POSTGRES_DB=sailboats_fleet
POSTGRES_USER=sailboats
# Use a long random value, e.g. `openssl rand -base64 24`.
POSTGRES_PASSWORD=change-me-to-a-strong-secret

# --- MS SQL Server (only when running with --profile telemetry) ---
# Must satisfy SQL Server complexity rules (upper, lower, digit, symbol, 8+).
MSSQL_SA_PASSWORD=Change-Me-Strong!2026
